<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><h1>İl Admin Paneli</h1><p>Adıyaman ilindeki kütüphaneler, kart önerileri ve etkinlikler.</p><div class="library-grid"><% d.libraries.forEach(l=>{ %><div class="library-card"><div class="big"><%= l.logo %></div><h2><%= l.name %></h2><p><%= d.cards.filter(c=>c.libraryId===l.id).length %> kart • <%= d.events.filter(e=>e.libraryId===l.id).length %> etkinlik</p></div><% }) %></div></main></body></html>
