<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><section class="lib-hero"><div class="big"><%= lib.logo %></div><div><h1><%= lib.name %></h1><p><%= lib.city %> / <%= lib.district %></p><b><%= lib.banner %></b></div></section><h2>Bu Kütüphaneden Kazanılan Kartlar</h2><div class="cards"><% d.cards.filter(c=>c.libraryId===lib.id && c.status==='approved').forEach(c=>{ %><div class="game-card <%= c.rarity.toLowerCase() %>"><div class="card-front"><div class="top"><span><%= c.rarity %></span><b><%= c.element %></b></div><div class="icon"><%= c.icon %></div><h3><%= c.title %></h3><p><%= c.lore %></p><small>Kazandıran Kütüphane:<br><b><%= lib.name %></b></small><div class="stats">⚔ <%= c.attack %> 🛡 <%= c.defense %> ⚡ <%= c.power %></div></div></div><% }) %></div><h2>Etkinlikler</h2><div class="list"><% d.events.filter(e=>e.libraryId===lib.id).forEach(e=>{ %><div class="row"><b><%= e.title %></b><span><%= e.date %> <%= e.time %></span><p><%= e.description %></p></div><% }) %></div></main></body></html>
