<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %>
<section class="hero"><div><h1>Kütüphane Efsaneleri</h1><p>Kitap ödünç al, etkinliklere katıl, kültürel miras kartlarını koleksiyonuna ekle.</p><a class="btn" href="/cards">Kartları İncele</a><a class="btn ghost" href="/presentation">IFLA 100. Yıl Sunum Modu</a></div><div class="hero-card">📚<b>Oyunlaştırılmış Kütüphane Ekosistemi</b><span>Okuma + Etkinlik + Koleksiyon</span></div></section>
<section class="grid2"><div class="panel"><h2>Kütüphane Başvurusu</h2><form method="post" action="/library-apply"><input name="name" placeholder="Kütüphane adı" required><input name="city" placeholder="İl" required><input name="district" placeholder="İlçe" required><input name="adminEmail" placeholder="Yetkili e-posta" required><button>Başvuru Gönder</button></form></div><div class="panel"><h2>Öne Çıkan Kartlar</h2><div class="cards"><% d.cards.slice(0,3).forEach(c=>{ const lib=d.libraries.find(l=>l.id===c.libraryId); %><div class="game-card <%= c.rarity.toLowerCase() %>"><div class="card-front"><div class="top"><span><%= c.rarity %></span><b><%= c.element %></b></div><div class="icon"><%= c.icon %></div><h3><%= c.title %></h3><small>Kazandıran Kütüphane:<br><b><%= lib?.name %></b></small><p><%= c.lore %></p><div class="stats">⚔ <%= c.attack %> 🛡 <%= c.defense %> ⚡ <%= c.power %></div></div></div><% }) %></div></div></section>
<%- include('footer') %></body></html>
