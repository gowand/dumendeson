<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><h1>Kart Koleksiyonu</h1><p class="muted">Kartların ön yüzünde hangi kütüphaneden kazanıldığı ve kilitli kartlarda nasıl açılacağı gösterilir.</p><div class="cards"><% d.cards.filter(c=>c.status==='approved').forEach(c=>{ const lib=d.libraries.find(l=>l.id===c.libraryId); let p=user&&user.role==='USER'?progress(d,user.id,c):null; %><div class="game-card <%= c.rarity.toLowerCase() %> <%= p&&!p.unlocked?'locked':'' %>"><div class="card-front"><div class="top"><span><%= c.rarity %></span><b><%= c.element %></b></div><div class="icon"><%= c.icon %></div><h3><%= c.title %></h3><small>Kazandıran Kütüphane:<br><b><%= lib?.name %></b></small><p><%= c.lore %></p><div class="stats">⚔ <%= c.attack %> 🛡 <%= c.defense %> ⚡ <%= c.power %></div><div class="requirements"><b>Gerekli:</b> <%= c.requiredBooks %> kitap • <%= c.requiredPoints %> puan • Level <%= c.requiredLevel %></div><% if(p && !p.unlocked){ %><div class="how"><b>Nasıl açılır?</b><br><%= p.remainingBooks %> kitap, <%= p.remainingPoints %> puan kaldı. Levelın: <%= p.lvl %>. <% if(p.missingBooks.length){ %>Özel kitap: <%= p.missingBooks.join(', ') %> gerekli.<% } %><% if(c.type==='event'){ %><%= c.eventRequirement %><% } %></div><% } else if(p&&p.unlocked){ %><div class="opened">Açıldı ✅</div><% } else { %><div class="how">Giriş yapınca kişisel ilerlemeni görürsün.</div><% } %></div></div><% }) %></div></main></body></html>
