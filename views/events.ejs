<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><h1>Etkinlikler</h1><div class="list"><% d.events.forEach(e=>{ const lib=d.libraries.find(l=>l.id===e.libraryId); const card=d.cards.find(c=>c.id===e.cardId); %><div class="event"><h2><%= e.title %></h2><p><%= lib?.name %> • <%= e.date %> <%= e.time %> • Kontenjan: <%= e.quota %></p><p><%= e.description %></p><p>Ödül: <%= e.points %> puan <% if(card){ %> + <b><%= card.title %></b><% } %></p><% if(user&&user.role==='USER'&&e.status==='active'){ %><form method="post" action="/events/<%= e.id %>/apply" class="inline"><input name="tc" placeholder="TC" required><input name="phone" placeholder="Telefon" required><input name="age" placeholder="Yaş" required><input name="note" placeholder="Not"><button>Başvur</button></form><% } %></div><% }) %></div></main></body></html>
