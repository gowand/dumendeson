<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><h1><%= lib.name %> Paneli</h1><div class="grid2"><div class="panel"><h2>TC ile Ödünç Ver</h2><form method="post" action="/library-admin/loan"><input name="tc" placeholder="Üye TC" required><select name="bookId"><% d.books.filter(b=>b.libraryId===lib.id).forEach(b=>{ %><option value="<%= b.id %>"><%= b.title %> (+<%= b.points %>)</option><% }) %></select><button>Ödünç İşle</button></form></div><div class="panel"><h2>Kitap Ekle</h2><form method="post" action="/library-admin/books/add"><input name="title" placeholder="Kitap adı"><input name="author" placeholder="Yazar"><input name="category" placeholder="Kategori"><input name="points" type="number" placeholder="Puan"><label><input type="checkbox" name="isSpecial"> Özel/nadir kart şartı</label><button>Ekle</button></form></div></div><div class="grid2"><div class="panel"><h2>Etkinlik Oluştur</h2><form method="post" action="/library-admin/events/add"><input name="title" placeholder="Etkinlik adı"><input name="date" type="date"><input name="time" type="time"><input name="quota" type="number" placeholder="Kontenjan"><input name="age" placeholder="Yaş aralığı"><input name="points" type="number" placeholder="Puan"><select name="cardId"><option value="">Kart yok</option><% d.cards.filter(c=>c.libraryId===lib.id).forEach(c=>{ %><option value="<%= c.id %>"><%= c.title %></option><% }) %></select><textarea name="description" placeholder="Açıklama"></textarea><button>Etkinlik Ekle</button></form></div><div class="panel"><h2>Kart Öner</h2><form method="post" action="/library-admin/card-suggest"><input name="title" placeholder="Kart adı"><select name="rarity"><option>Common</option><option>Rare</option><option>Epic</option><option>Legendary</option><option>Mythic</option></select><input name="element" placeholder="Element"><select name="icon"><% ['👑','☀️','⛰️','🌉','🏰','🦅','📚','🔥','💎','🛡️','⚔️','🗝️','🏺','🌙','⭐','🐺','🐉','🦉','🌊','🌲'].forEach(i=>{ %><option><%= i %></option><% }) %></select><input name="requiredBooks" type="number" placeholder="Gerekli kitap"><input name="requiredPoints" type="number" placeholder="Gerekli puan"><input name="requiredLevel" type="number" placeholder="Level"><textarea name="lore" placeholder="Kart hikâyesi"></textarea><button>Onaya Gönder</button></form><p class="muted">Not: Gerçek sürümde 1000+ ikon arama havuzu eklenebilir.</p></div></div><h2>Etkinlik Başvuruları</h2><div class="list"><% d.applications.filter(a=>{const e=d.events.find(x=>x.id===a.eventId);return e&&e.libraryId===lib.id}).forEach(a=>{ const e=d.events.find(x=>x.id===a.eventId); const u=d.users.find(x=>x.id===a.userId); %><div class="row"><b><%= e.title %></b><span><%= u.name %> • TC: <%= maskTc(a.tc) %> • Tel: <%= a.phone %> • <%= a.status %></span><form method="post" action="/library-admin/applications/<%= a.id %>/approved" class="inline"><button>Onayla</button></form><form method="post" action="/library-admin/applications/<%= a.id %>/attended" class="inline"><button>Katıldı</button></form><form method="post" action="/library-admin/applications/<%= a.id %>/rejected" class="inline"><button>Reddet</button></form></div><% }) %></div><h2>Etkinlik Arşivi</h2><div class="list"><% d.events.filter(e=>e.libraryId===lib.id).forEach(e=>{ %><div class="row"><b><%= e.title %></b><span><%= e.status %> • Başvuru: <%= d.applications.filter(a=>a.eventId===e.id).length %></span></div><% }) %></div></main></body></html>
