<!doctype html><html><head><%- include('head') %></head><body><%- include('nav') %><main><h1>Süper Admin</h1><div class="grid2"><div class="panel"><h2>Kart Önerileri</h2><% d.cardSuggestions.forEach(s=>{ const lib=d.libraries.find(l=>l.id===s.libraryId); %><div class="row"><b><%= s.icon %> <%= s.title %></b><span><%= lib?.name %> • <%= s.status %></span><form method="post" action="/admin/card-suggestions/<%= s.id %>/approve"><button>Onayla</button></form></div><% }) %></div><div class="panel"><h2>Kütüphane Başvuruları</h2><% d.libraryApplications.forEach(a=>{ %><div class="row"><b><%= a.name %></b><span><%= a.city %>/<%= a.district %> • <%= a.status %></span><form method="post" action="/admin/library-applications/<%= a.id %>/approve"><button>Onayla</button></form></div><% }) %></div></div><h2>Raporlama</h2><div class="statsbox"><div>Kullanıcı: <b><%= d.users.filter(u=>u.role==='USER').length %></b></div><div>Kütüphane: <b><%= d.libraries.length %></b></div><div>Kart: <b><%= d.cards.length %></b></div><div>Ödünç: <b><%= d.loans.length %></b></div><div>Etkinlik: <b><%= d.events.length %></b></div></div></main></body></html>
